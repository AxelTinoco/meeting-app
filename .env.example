# --- Google service account (domain-wide delegation) ---
# Autoriza el Client ID de la SA en Admin Console con los scopes:
#   https://www.googleapis.com/auth/calendar.events
#   https://www.googleapis.com/auth/calendar.readonly
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# PEM PKCS#8. En una sola línea con \n escapados, o multilínea entre comillas.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_WORKSPACE_DOMAIN=gerundio.mx

# --- OAuth client (login del equipo, roadmap paso 5) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Nota (Cloudflare Workers): en dev, copia estas vars a `.dev.vars`.
# En producción usa `wrangler secret put <NOMBRE>` (no las pongas en wrangler.jsonc).
# Sin credenciales, la app corre en "modo demo" con datos mock.
